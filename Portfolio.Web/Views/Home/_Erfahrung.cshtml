<section class="block" id="cv">
    <div class="wrap">
        <div class="block-head reveal">
            <span class="section-tag">06 — Werdegang</span>
            <h2 class="section-title">Erfahrung &amp; Bildung</h2>
        </div>
        <div class="cv-groups reveal">
            <div class="cv-group">
                <h3 class="cv-title">Berufserfahrung</h3>
                <div class="timeline">
                    <div class="tl-item">
                        <span class="when">2024 — heute</span>
                        <h4>Freiberuflicher Webentwickler</h4>
                        <div class="where">Selbstständig · Teilzeit · Teheran</div>
                        <p>
                            Kleine Web-Anwendungen und Websites für lokale Kunden — von der Idee über die
                            Umsetzung mit ASP.NET&nbsp;Core bis zum Deployment.
                        </p>
                    </div>
                    <div class="tl-item">
                        <span class="when">2023 — 2024</span>
                        <h4>IT-Support (Praktikum)</h4>
                        <div class="where">[Firmenname], Teheran</div>
                        <p>
                            Anwender-Support, Fehlersuche bei Software- und Netzwerkproblemen sowie
                            Dokumentation interner Abläufe.
                        </p>
                    </div>
                </div>
            </div>
            <div class="cv-group">
                <h3 class="cv-title">Bildung</h3>
                <div class="timeline">
                    <div class="tl-item">
                        <span class="when">2025 — 2026</span>
                        <h4>Deutschkurs (A1 → B2)</h4>
                        <div class="where">[Sprachinstitut]</div>
                        <p>
                            Intensiver Sprachkurs zur Vorbereitung auf Ausbildung, Beruf und Alltag in
                            Deutschland.
                        </p>
                    </div>
                    <div class="tl-item">
                        <span class="when">2020 — 2024</span>
                        <h4>Hochschuldiplom — Informatik</h4>
                        <div class="where">[Universität], Teheran</div>
                        <p>Grundlagen der Programmierung, Datenstrukturen, Algorithmen und Datenbanken.</p>
                    </div>
                    <div class="tl-item">
                        <span class="when">2022 — heute</span>
                        <h4>Online-Zertifikate &amp; Selbststudium</h4>
                        <div class="where">Microsoft Learn · Udemy · eigene Projekte</div>
                        <p>C#, ASP.NET&nbsp;Core, Entity Framework und SQL — durch Kurse und eigene Projekte.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>