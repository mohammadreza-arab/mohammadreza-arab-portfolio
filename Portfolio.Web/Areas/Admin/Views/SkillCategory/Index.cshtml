@model IEnumerable<SkillCategory>;
<div class="topbar">
    <div style="display:flex;align-items:center;gap:14px;">
        <button class="menu-toggle" onclick="toggleMenu(true)" aria-label="Menü"><svg class="ic" viewBox="0 0 24 24"><path d="M3 6h18M3 12h18M3 18h18"></path></svg></button>
        <div>
            <h1>Skill Category</h1>
        </div>
    </div>
    <a asp-area="Admin" asp-controller="SkillCategory" asp-action="Create" class="btn btn-primary">
        <svg class="ic" viewBox="0 0 24 24"><path d="M5 12l5 5L20 7"></path></svg> Speichern
    </a>
</div>
<section class="view active" id="view-entity">
    <div class="panel">
        <div id="tableHost">
            <div class="table-scroll">
                <table>
                    <thead><tr><th>Name</th><th>Skills</th><th>Button</th></tr></thead>
                    <tbody>
                        @foreach(var item in Model)
                        {
                            <tr>
                                <td><div class="t-title">@item.Name</div></td>
                                <td>
                                @foreach (var skill in item.Skills)
                                {
                                    <div class="t-sub">@skill.SkillsTitle</div>
                                }
                                </td>
                                <td>
                                    <div class="row-actions" style="justify-content:center;">
                                        <a class="icon-btn" asp-area="Admin" asp-controller="SkillCategory" asp-action="Edit" asp-route-id="@item.Id" aria-label="Bearbeiten"><svg class="ic" viewBox="0 0 24 24"><path d="M12 20h9"></path><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"></path></svg></a>
                                        <a asp-area="admin" asp-controller="SkillCategory" asp-action="Delete" asp-route-id="@item.Id" class="icon-btn del" aria-label="Löschen"><svg class="ic" viewBox="0 0 24 24"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"></path></svg></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
