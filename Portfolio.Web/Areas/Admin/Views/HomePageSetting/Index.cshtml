@model Portfolio.Web.Models.HomePageSetting;
<div class="topbar">
    <div style="display:flex;align-items:center;gap:14px;">
        <button class="menu-toggle" onclick="toggleMenu(true)" aria-label="Menü"><svg class="ic" viewBox="0 0 24 24"><path d="M3 6h18M3 12h18M3 18h18"></path></svg></button>
        <div>
            <h1 id="pageTitle">HomePageSetting</h1>
            <div class="sub" id="pageSub">Überblick über deine Inhalte</div>
        </div>
    </div>
    <button class="btn btn-primary" id="addBtn" onclick="goForm()" style="display: none;">
        <svg class="ic" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"></path></svg>
        <span id="addLabel">HomePageSetting</span>
    </button>
</div>
<section class="view active" id="view-entity">
    <div class="panel">
        <div id="tableHost">
            <div class="table-scroll">
                <table>
                    <thead><tr><th>Vorschau</th><th>Meta Title</th><th>Meta Description</th><th style="text-align:right">Hero Title</th></tr></thead>
                    <tbody>
                        <tr>
                            <td><div class="t-sub-img" "><img src="~/Images/hero/@Model.HeroImageName" alt="" /></div></td>
                            <td><div class="t-title">@Model.MetaTitle</div></td>
                            <td><div class="t-sub">@Model.MetaDescription</div></td>
                            <td><div class="t-sub">@Model.HeroTitle</div></td>
                            <td>
                                <div class="row-actions">
                                    <button class="icon-btn"  aria-label="Bearbeiten"><svg class="ic" viewBox="0 0 24 24"><path d="M12 20h9"></path><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"></path></svg></button>
                                    <button class="icon-btn del"  aria-label="Löschen"><svg class="ic" viewBox="0 0 24 24"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"></path></svg></button>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>