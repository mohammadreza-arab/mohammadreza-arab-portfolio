@model HomePageSetting
<div class="topbar">
    <div style="display:flex;align-items:center;gap:14px;">
        <div>
            <h1 id="pageTitle">HomePageSetting Delete</h1>
        </div>
    </div>
</div>
<div class="form-card">
    <div class="fc-body">
        <form asp-action="Delete"
              asp-controller="HomePageSetting"
              asp-area="Admin"
              method="post"
              enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="HeroImageName" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <h3>Hero</h3>
            <div class="field-grid">
                <div class="field">
                    <label asp-for="HeroName"></label>
                    <input asp-for="HeroName" class="form-control" />
                </div>
                <div class="field">
                    <label asp-for="HeroTitle"></label>
                    <input asp-for="HeroTitle" class="form-control" />
                </div>
                <div class="field span2">
                    <label asp-for="HeroDescription"></label>
                    <textarea asp-for="HeroDescription" class="form-control" id="editor"></textarea>
                </div>
                <div class="field span2">
                    <img src="~/Images/hero/@Model.HeroImageName" style="width: 10%;
                    border-radius: 10px;" />
                    <label asp-for="HeroImageName"></label>
                    <input type="file" name="HeroImageFile" class="form-control" />
                </div>
                <div class="field">
                    <label asp-for="HeroLocation"></label>
                    <input asp-for="HeroLocation" class="form-control" />
                </div>
                <div class="field">
                    <label asp-for="HeroStatus"></label>
                    <input asp-for="HeroStatus" class="form-control" />
                </div>

                <div class="field">
                    <label asp-for="HeroFocus"></label>
                    <input asp-for="HeroFocus" class="form-control" />
                </div>
                <div class="field">
                    <label asp-for="HeroLanguage"></label>
                    <input asp-for="HeroLanguage" class="form-control" />
                </div>
            </div>
            <h3>About</h3>
            <div class="field-grid">
                <div class="field">
                    <label asp-for="AboutTitle"></label>
                    <input asp-for="AboutTitle" class="form-control" />
                </div>
                <div class="field">
                    <label asp-for="AboutSummary"></label>
                    <input asp-for="AboutSummary" class="form-control" />
                </div>
                <div class="field span2">
                    <label asp-for="AboutDescription"></label>
                    <textarea asp-for="AboutDescription" class="form-control" id="editorr"></textarea>
                </div>
            </div>
            <h3>Contact</h3>
            <div class="field-grid">
                <div class="field">
                    <label asp-for="TitleContact"></label>
                    <input asp-for="TitleContact" class="form-control" />
                </div>
                <div class="field">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" />
                </div>
                <div class="field">
                    <label asp-for="EmailUrl"></label>
                    <input asp-for="EmailUrl" class="form-control" />
                </div>
                <div class="field">
                    <label asp-for="GithubUrl"></label>
                    <input asp-for="GithubUrl" class="form-control" />
                </div>
                <div class="field">
                    <label asp-for="LinkedinUrl"></label>
                    <input asp-for="LinkedinUrl" class="form-control" />
                </div>
            </div>
            <h3>SEO</h3>
            <div class="field-grid">
                <div class="field">
                    <label asp-for="MetaTitle"></label>
                    <input asp-for="MetaTitle" class="form-control" />
                </div>
                <div class="field span2">
                    <label asp-for="MetaDescription"></label>
                    <textarea asp-for="MetaDescription" class="form-control"></textarea>
                </div>
            </div>
            <button type="submit" class="btn btn-danger">
                Delete
            </button>
            <a asp-area="admin" asp-controller="HomePageSetting" asp-action="index" class="btn btn-danger">
                Cancel
            </a>
        </form>
    </div>
</div>

@section Style
{
    <link href="~/lib/ckeditor/css/ckeditor5.css" rel="stylesheet" />
    <link href="~/lib/ckeditor/css/ckeditor5-content.css" rel="stylesheet" />
    <link href="~/lib/ckeditor/css/ckeditor5-editor.css" rel="stylesheet" />
}
@section Scripts
{
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script type="module">

        import { ClassicEditor, editorConfig }
        from '/lib/ckeditor/js/ckeditor-config.js';

        ClassicEditor
        .create(
        document.querySelector('#editor'),
        editorConfig
        )
        .then(editor => {
        console.log(editor);
        })
        .catch(error => {
        console.error(error);
        });

        ClassicEditor
        .create(
        document.querySelector('#editorr'),
        editorConfig
        )
        .then(editor => {
        console.log(editor);
        })
        .catch(error => {
        console.error(error);
        });
    </script>

}
